				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-std=c++17" />
					<Add directory="../curl-8.19.0/include" />
					<Add directory="cpp-httplib" />
					<Add directory="include" />
					<Add directory="src/server" />
					<Add directory="." />
				</Compiler>
				<Linker>
					<Add option="-L../curl-8.19.0/lib" />
					<Add option="-lcurl" />
					<Add option="-lwtsapi32" />
					<Add option="-lws2_32" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/KindyunAI" prefix_auto="1" extension_auto="1" />
