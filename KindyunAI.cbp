					<Add directory="." />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add option="-L../curl-8.19.0/lib" />
					<Add option="-lcurl" />
					<Add option="-lwtsapi32" />
					<Add option="-lws2_32" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add option="-D_WIN32_WINNT=0x0A00" />
